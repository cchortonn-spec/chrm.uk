# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it holds secrets.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Microsoft Clarity project ID (optional — only loads after analytics consent)
NEXT_PUBLIC_CLARITY_ID=

# WhatsApp number in international format, digits only (no +, no spaces)
# RIGN business WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=44739839541

# Resend API key from https://resend.com
RESEND_API_KEY=

# Where contact form emails are delivered (inbox)
CONTACT_EMAIL_TO=rign.uk@gmail.com

# Public site URL — used for sitemap, robots, and Open Graph tags
NEXT_PUBLIC_SITE_URL=https://rign.uk
